{
  "name": "ddd-arch",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Deterministic DDD + clean/onion architecture conventions for NestJS, enforced by ESLint.",
  "license": "MIT",
  "author": "Amr Abdelaziz (https://github.com/swe-amr-abdelaziz)",
  "repository": {
    "type": "git",
    "url": "https://github.com/swe-amr-abdelaziz/ddd-arch.git"
  },
  "scripts": {
    "changeset": "changeset",
    "version": "changeset version",
    "release": "changeset publish",
    "typecheck": "tsc",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "doc:check": "pnpm -C packages/eslint-plugin doc:check"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@ddd-arch/eslint-plugin": "workspace:*",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-eslint-plugin": "^7.4.0",
    "prettier": "^3.8.5",
    "typescript": "^6.0.3"
  }
}
